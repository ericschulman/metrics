# ============================================================
# Repo-specific rule:
#   In selected_topics/, do NOT track bulky artifacts (data/pdfs/tex/etc).
#   These filetypes are still allowed elsewhere (e.g., ut_austin_metrics/).
# ============================================================

# Data files
selected_topics/**/*.csv
selected_topics/**/*.tsv
selected_topics/**/*.dta
selected_topics/**/*.sav
selected_topics/**/*.parquet
selected_topics/**/*.feather
selected_topics/**/*.xlsx
selected_topics/**/*.xls

# TeX / LaTeX build + sources
selected_topics/**/*.tex
selected_topics/**/*.bib
selected_topics/**/*.aux
selected_topics/**/*.bbl
selected_topics/**/*.blg
selected_topics/**/*.fdb_latexmk
selected_topics/**/*.fls
selected_topics/**/*.log
selected_topics/**/*.out
selected_topics/**/*.synctex*
selected_topics/**/*.toc

# Documents
selected_topics/**/*.pdf

# Common archives (often used for sharing data/output)
selected_topics/**/*.zip
selected_topics/**/*.tar
selected_topics/**/*.tar.gz
selected_topics/**/*.tgz
selected_topics/**/*.gz
selected_topics/**/*.7z